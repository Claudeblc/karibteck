---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  seed: string;
  category?: string;
  size?: 'lg' | 'sm';
  image?: ImageMetadata;
  alt?: string;
  eager?: boolean;
}
const { seed, category, size = 'sm', image, alt = '', eager = false } = Astro.props;
const LETTERS = ['a', 'b', 'c', 'd'] as const;
let hash = 0;
for (const ch of seed) hash = (hash * 31 + ch.charCodeAt(0)) >>> 0;
const letter = LETTERS[hash % LETTERS.length];
---

<div
  class:list={['cover', `cover-${size}`, { 'cover-image': image }]}
  style={image ? undefined : `background: var(--gradient-cover-${letter})`}
>
  {
    image && (
      <Image
        class="cover-img"
        src={image}
        alt={alt}
        widths={size === 'lg' ? [480, 720, 960] : [320, 480, 640]}
        sizes={size === 'lg' ? '(max-width: 860px) 100vw, 50vw' : '(max-width: 700px) 100vw, 360px'}
        loading={eager ? 'eager' : 'lazy'}
      />
    )
  }
  {category && <span class="cover-cat">{category}</span>}
</div>

<style>
  .cover {
    position: relative;
    border-radius: var(--radius-lg) var(--radius-lg) 0 0;
    display: flex;
    align-items: flex-end;
    padding: 16px;
    overflow: hidden;
  }
  .cover-sm {
    height: 160px;
  }
  .cover-lg {
    height: 100%;
    min-height: 280px;
    border-radius: var(--radius-lg);
  }
  .cover-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .cover-cat {
    position: relative;
    background: rgba(0, 0, 0, 0.45);
    color: var(--color-on-primary);
    font-family: var(--font-label);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 4px 12px;
    border-radius: var(--radius-pill);
    backdrop-filter: blur(4px);
  }
</style>
