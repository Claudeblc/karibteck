---
import { Icon } from 'astro-icon/components';
import { WHATSAPP_NUMBER, DEFAULT_LOCALE } from '@/lib/constants';
import { useTranslations } from '@/i18n/utils';
import type { Locale } from '@/types';

interface Props {
  locale?: Locale;
}
const { locale = DEFAULT_LOCALE } = Astro.props;
const t = useTranslations(locale);
const href = WHATSAPP_NUMBER ? `https://wa.me/${WHATSAPP_NUMBER}` : undefined;
---

{
  href && (
    <a href={href} target="_blank" rel="noopener noreferrer" class="wa-btn">
      <Icon name="simple-icons:whatsapp" />
      {t('contact.whatsapp')}
    </a>
  )
}

<style>
  .wa-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 12px 22px;
    border-radius: var(--radius-pill);
    background: var(--color-surface-gray);
    border: 1px solid var(--color-surface-gray);
    color: var(--color-on-surface);
    font-family: var(--font-label);
    text-decoration: none;
    font-weight: 600;
    transition:
      border-color 0.2s,
      color 0.2s;
  }
  .wa-btn:hover {
    border-color: var(--color-teal);
    color: var(--color-teal);
  }
  .wa-btn :global(svg) {
    width: 18px;
    height: 18px;
  }
</style>
