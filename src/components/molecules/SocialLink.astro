---
import { Icon } from 'astro-icon/components';
import type { SocialLink } from '@/types';

interface Props {
  link: SocialLink;
}
const { link } = Astro.props;
---

<a
  href={link.href}
  class="social-btn"
  title={link.label}
  aria-label={link.label}
  rel="noopener noreferrer"
>
  <Icon name={link.icon} />
</a>

<style>
  .social-btn {
    width: 38px;
    height: 38px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    border: 1px solid var(--color-gray-2);
    color: var(--color-gray);
    text-decoration: none;
    transition:
      background 0.2s,
      border-color 0.2s,
      color 0.2s;
  }
  .social-btn :global(svg) {
    width: 18px;
    height: 18px;
  }
  .social-btn:hover {
    background: var(--color-overlay-accent-social);
    border-color: var(--color-blue-2);
    color: var(--color-white);
  }
</style>
