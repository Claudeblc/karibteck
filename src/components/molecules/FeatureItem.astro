---
import type { Feature } from '@/types';

interface Props {
  feature: Feature;
}
const { feature } = Astro.props;
---

<div class="feat-item">
  <div class="feat-icon">{feature.icon}</div>
  <div>
    <div class="feat-title">{feature.title}</div>
    <div class="feat-sub">{feature.subtitle}</div>
  </div>
</div>

<style>
  .feat-item {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 0.88rem;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.85);
  }
  .feat-icon {
    width: 36px;
    height: 36px;
    background: linear-gradient(135deg, rgba(0, 87, 231, 0.25), rgba(0, 212, 255, 0.15));
    border: 1px solid rgba(0, 153, 255, 0.25);
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1rem;
  }
  .feat-sub {
    font-size: 0.72rem;
    font-weight: 400;
    color: var(--color-gray);
  }
</style>
