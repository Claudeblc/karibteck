---
import { Icon } from 'astro-icon/components';
import type { Feature } from '@/types';

interface Props {
  feature: Feature;
}
const { feature } = Astro.props;
---

<div class="feat-item">
  <div class="feat-icon"><Icon name={feature.icon} /></div>
  <div>
    <div class="feat-title">{feature.title}</div>
    <div class="feat-sub">{feature.subtitle}</div>
  </div>
</div>

<style>
  .feat-item {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 0.88rem;
    font-weight: 600;
    color: var(--color-on-surface);
  }
  .feat-icon {
    width: 36px;
    height: 36px;
    background: var(--color-overlay-teal);
    border: 1px solid var(--color-surface-gray);
    border-radius: var(--radius-card);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-teal);
  }
  .feat-icon :global(svg) {
    width: 20px;
    height: 20px;
  }
  .feat-sub {
    font-size: 0.72rem;
    font-weight: 400;
    color: var(--color-on-surface-variant);
  }
</style>
