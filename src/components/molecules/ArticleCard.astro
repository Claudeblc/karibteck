---
import Tag from '@/components/atoms/Tag.astro';
import ArticleCover from '@/components/molecules/ArticleCover.astro';
import { formatDate } from '@/lib/dates';
import { useTranslations } from '@/i18n/utils';
import type { Locale } from '@/types';

interface Props {
  href: string;
  title: string;
  excerpt: string;
  date: Date;
  readingMinutes: number;
  tags: string[];
  locale: Locale;
}
const { href, title, excerpt, date, readingMinutes, tags, locale } = Astro.props;
const t = useTranslations(locale);
---

<article class="article-card fade-up">
  <a class="article-cover-link" href={href} tabindex="-1" aria-hidden="true">
    <ArticleCover seed={href} category={tags[0]} size="sm" />
  </a>
  <div class="article-body">
    <p class="article-meta">
      {formatDate(date, locale)} · {readingMinutes}
      {t('blog.readingTime')}
    </p>
    <h3 class="article-title"><a href={href}>{title}</a></h3>
    <p class="article-excerpt">{excerpt}</p>
    <div class="article-tags">
      {tags.map((tag) => <Tag label={tag} />)}
    </div>
  </div>
</article>

<style>
  .article-card {
    display: flex;
    flex-direction: column;
    background: var(--color-surface-card);
    border: 1px solid var(--color-surface-gray);
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-card);
    transition:
      transform 0.3s,
      box-shadow 0.3s;
  }
  .article-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-card-hover);
  }
  .article-cover-link {
    display: block;
  }
  .article-body {
    display: flex;
    flex-direction: column;
    flex: 1;
    padding: 28px;
  }
  .article-meta {
    color: var(--color-on-surface-variant);
    font-size: 0.85rem;
  }
  .article-title {
    font-family: var(--font-display);
    font-size: 1.25rem;
    margin: 12px 0 10px;
    color: var(--color-on-surface);
  }
  .article-title a {
    color: inherit;
    text-decoration: none;
  }
  .article-title a:hover {
    color: var(--color-teal);
  }
  .article-excerpt {
    color: var(--color-on-surface-variant);
    font-size: 0.95rem;
    flex: 1;
  }
  .article-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 16px;
  }
</style>
