---
import { Icon } from 'astro-icon/components';
import type { TechLogo } from '@/types';

interface Props {
  logo: TechLogo;
}
const { logo } = Astro.props;
---

<div class="tech-logo">
  <span class="tech-logo-icon" style={`color:${logo.color}`}><Icon name={logo.icon} /></span>
  <span class="tech-logo-name">{logo.name}</span>
</div>

<style>
  .tech-logo {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    opacity: 0.55;
    filter: grayscale(1);
    transition:
      opacity 0.3s,
      filter 0.3s;
    cursor: default;
  }
  .tech-logo:hover {
    opacity: 1;
    filter: grayscale(0);
  }
  .tech-logo-icon {
    line-height: 1;
  }
  .tech-logo-icon :global(svg) {
    width: 28px;
    height: 28px;
  }
  .tech-logo-name {
    font-family: var(--font-label);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    color: var(--color-on-surface-variant);
  }
</style>
