---
import { Icon } from 'astro-icon/components';
import type { Guarantee } from '@/types';

interface Props {
  guarantee: Guarantee;
}
const { guarantee } = Astro.props;
---

<article class="guarantee fade-up">
  <div class="icon" aria-hidden="true"><Icon name={guarantee.icon} /></div>
  <div>
    <h3 class="title">{guarantee.title}</h3>
    <p class="desc">{guarantee.description}</p>
  </div>
</article>

<style>
  .guarantee {
    display: flex;
    gap: 16px;
    padding: 20px;
    background: var(--color-navy-2);
    border: 1px solid var(--color-gray-2);
    border-radius: var(--radius-card);
  }
  .icon {
    line-height: 1;
    flex-shrink: 0;
    color: var(--color-cyan);
  }
  .icon :global(svg) {
    width: 28px;
    height: 28px;
  }
  .title {
    font-family: var(--font-display);
    font-size: 1.02rem;
    margin-bottom: 6px;
  }
  .desc {
    color: var(--color-gray);
    font-size: 0.92rem;
  }
</style>
