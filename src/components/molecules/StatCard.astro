---
import type { Stat } from '@/types';

interface Props {
  stat: Stat;
}
const { stat } = Astro.props;
---

<div class="why-stat">
  <div class="why-stat-num">{stat.value}</div>
  <div class="why-stat-label">{stat.label}</div>
</div>

<style>
  .why-stat {
    background: rgba(0, 87, 231, 0.08);
    border: 1px solid rgba(0, 153, 255, 0.15);
    border-radius: var(--radius-card);
    padding: 20px;
    text-align: center;
  }
  .why-stat-num {
    font-family: var(--font-display);
    font-size: 2.2rem;
    font-weight: 800;
    background: linear-gradient(135deg, #4da6ff, #00d4ff);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .why-stat-label {
    font-size: 0.82rem;
    color: var(--color-gray);
    margin-top: 4px;
  }
</style>
