---
import { Icon } from 'astro-icon/components';
import Tag from '@/components/atoms/Tag.astro';
import Button from '@/components/atoms/Button.astro';
import ReassuranceStrip from '@/components/molecules/ReassuranceStrip.astro';
import Callout from '@/components/molecules/Callout.astro';
import CheckList from '@/components/molecules/CheckList.astro';
import FaqList from '@/components/molecules/FaqList.astro';
import { useTranslations, localizePath } from '@/i18n/utils';
import { DEFAULT_LOCALE } from '@/lib/constants';
import type { Locale, Service } from '@/types';

interface Props {
  service: Service;
  locale?: Locale;
}
const { service, locale = DEFAULT_LOCALE } = Astro.props;
const t = useTranslations(locale);
const homePath = localizePath('home', locale);
const contactHref = localizePath('contact', locale);
const servicesHref = localizePath('services', locale);
---

<article class="service-detail">
  <nav class="crumbs" aria-label="Breadcrumb">
    <a href={homePath}>{t('nav.home')}</a>
    <span aria-hidden="true">›</span>
    <a href={servicesHref}>{t('services.detail.breadcrumb')}</a>
  </nav>

  <header class="head">
    <div class="icon" aria-hidden="true"><Icon name={service.icon} /></div>
    <h1>{service.title}</h1>
    <p class="intro">{service.intro}</p>
    <Button href={contactHref} variant="primary">{t('services.detail.cta')}</Button>
    <ReassuranceStrip locale={locale} />
  </header>

  <Callout title={t('services.detail.problemTitle')} text={service.problem} variant="pain" />

  <CheckList title={t('services.detail.benefitsTitle')} items={service.benefits} />

  <CheckList title={t('services.detail.useCasesTitle')} items={service.useCases} />

  <Callout title={t('services.detail.resultTitle')} text={service.outcome} variant="gain" />

  <FaqList title={t('services.detail.faqTitle')} items={service.faq} />

  <section class="tech">
    <h2>{t('services.detail.techTitle')}</h2>
    <div class="tags">{service.tags.map((tag) => <Tag label={tag} />)}</div>
  </section>

  <div class="final-cta">
    <Button href={contactHref} variant="primary">{t('services.detail.cta')}</Button>
  </div>

  <a class="back" href={servicesHref}>← {t('services.detail.backToServices')}</a>
</article>

<style>
  .service-detail {
    max-width: 820px;
    margin: 0 auto;
    padding: calc(var(--nav-height) + 40px) 5% var(--section-pad-y);
  }
  .crumbs {
    display: flex;
    gap: 10px;
    color: var(--color-on-surface-variant);
    font-size: 0.85rem;
    margin-bottom: 32px;
  }
  .crumbs a {
    color: var(--color-on-surface-variant);
    text-decoration: none;
  }
  .crumbs a:hover {
    color: var(--color-teal);
  }
  .head .icon {
    color: var(--color-teal);
  }
  .head .icon :global(svg) {
    width: 42px;
    height: 42px;
  }
  .head h1 {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 3rem);
    margin: 12px 0 16px;
    color: var(--color-primary);
  }
  .intro {
    color: var(--color-on-surface-variant);
    font-size: 1.05rem;
    margin-bottom: 28px;
  }
  .head :global(.reassure) {
    margin-top: 18px;
  }
  .tech {
    margin-top: 48px;
  }
  .tech h2 {
    font-family: var(--font-display);
    font-size: 1.3rem;
    margin-bottom: 18px;
    color: var(--color-primary);
  }
  .final-cta {
    margin-top: 56px;
  }
  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  .back {
    display: inline-block;
    margin-top: 48px;
    color: var(--color-teal);
    text-decoration: none;
  }
</style>
