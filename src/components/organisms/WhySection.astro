---
import { WHY_POINTS, WHY_STATS, EXPERTISE_TAGS } from '@/data/why';
import WhyPoint from '@/components/molecules/WhyPoint.astro';
import StatCard from '@/components/molecules/StatCard.astro';
import SectionBadge from '@/components/atoms/SectionBadge.astro';
import Highlight from '@/components/atoms/Highlight.astro';
import Tag from '@/components/atoms/Tag.astro';
import { useTranslations } from '@/i18n/utils';
import { DEFAULT_LOCALE } from '@/lib/constants';
import type { Locale } from '@/types';

interface Props {
  locale?: Locale;
}
const { locale = DEFAULT_LOCALE } = Astro.props;
const t = useTranslations(locale);
---

<section id="pourquoi">
  <div class="section-inner">
    <div class="why-grid">
      <div class="fade-up">
        <SectionBadge label={t('why.badge')} />
        <h2 class="section-title">
          {t('why.title.lead')}
          <Highlight text={t('why.title.hl')} />
          {' '}{t('why.title.tail')}
        </h2>
        <p class="section-sub">{t('why.sub')}</p>
        <ul class="why-list">
          {WHY_POINTS.map((point) => <WhyPoint point={point} />)}
        </ul>
      </div>
      <div class="why-visual fade-up">
        <div class="why-stat-grid">
          {WHY_STATS.map((stat) => <StatCard stat={stat} />)}
        </div>
        <div class="why-expertise">
          <div class="why-expertise-label">{t('why.expertiseLabel')}</div>
          <div class="why-expertise-tags">
            {EXPERTISE_TAGS.map((label) => <Tag label={label} />)}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  #pourquoi {
    background: var(--color-navy-2);
    padding: var(--section-pad-y) 5%;
  }
  .section-inner {
    max-width: var(--content-max);
    margin: 0 auto;
  }
  .why-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: center;
  }
  .section-title {
    font-family: var(--font-display);
    font-size: clamp(1.8rem, 3.5vw, 2.8rem);
    font-weight: 800;
    line-height: 1.15;
    margin: 16px 0 14px;
  }
  .section-sub {
    color: var(--color-gray);
    font-size: 1rem;
    line-height: 1.7;
    margin-bottom: 32px;
  }
  .why-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 22px;
    padding: 0;
    margin: 0;
  }
  .why-visual {
    background: linear-gradient(160deg, #0f1e38, #071326);
    border: 1px solid rgba(0, 153, 255, 0.15);
    border-radius: var(--radius-lg);
    padding: 36px;
  }
  .why-stat-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }
  .why-expertise {
    margin-top: 24px;
    padding: 20px;
    background: rgba(0, 87, 231, 0.08);
    border: 1px solid rgba(0, 153, 255, 0.15);
    border-radius: var(--radius-card);
  }
  .why-expertise-label {
    font-size: 0.8rem;
    color: var(--color-cyan);
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 10px;
  }
  .why-expertise-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  @media (max-width: 860px) {
    .why-grid {
      grid-template-columns: 1fr;
    }
    .why-stat-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
