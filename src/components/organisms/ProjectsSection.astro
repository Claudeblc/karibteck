---
import { PROJECTS } from '@/data/projects';
import ProjectCard from '@/components/molecules/ProjectCard.astro';
import SectionBadge from '@/components/atoms/SectionBadge.astro';
import Highlight from '@/components/atoms/Highlight.astro';
import Button from '@/components/atoms/Button.astro';
import { useTranslations } from '@/i18n/utils';
import { DEFAULT_LOCALE } from '@/lib/constants';
import type { Locale } from '@/types';

interface Props {
  locale?: Locale;
}
const { locale = DEFAULT_LOCALE } = Astro.props;
const t = useTranslations(locale);
---

<section id="realisations">
  <div class="section-inner">
    <div class="section-head fade-up">
      <SectionBadge label={t('projects.badge')} />
      <h2 class="section-title">
        {t('projects.title.lead')}
        <Highlight text={t('projects.title.hl')} />
      </h2>
      <p class="section-sub">{t('projects.sub')}</p>
    </div>
    <div class="real-grid">
      {PROJECTS.map((project) => <ProjectCard project={project} />)}
    </div>
    <div class="projects-cta fade-up">
      <Button href="#contact" variant="outline">{t('cta.discussProject')}</Button>
    </div>
  </div>
</section>

<style>
  #realisations {
    background: var(--color-navy-2);
    padding: var(--section-pad-y) 5%;
  }
  .section-inner {
    max-width: var(--content-max);
    margin: 0 auto;
  }
  .section-title {
    font-family: var(--font-display);
    font-size: clamp(1.8rem, 3.5vw, 2.8rem);
    font-weight: 800;
    line-height: 1.15;
    margin: 16px 0 14px;
  }
  .section-sub {
    color: var(--color-gray);
    font-size: 1rem;
    max-width: 600px;
    line-height: 1.7;
    margin-bottom: 52px;
  }
  .real-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 24px;
  }
  .projects-cta {
    text-align: center;
    margin-top: 40px;
  }
</style>
