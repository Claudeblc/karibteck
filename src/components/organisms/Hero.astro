---
import { Image } from 'astro:assets';
import heroImage from '@/assets/hero.png';
import Highlight from '@/components/atoms/Highlight.astro';
import Button from '@/components/atoms/Button.astro';
import SectionBadge from '@/components/atoms/SectionBadge.astro';
import { useTranslations, localizePath } from '@/i18n/utils';
import { DEFAULT_LOCALE } from '@/lib/constants';
import type { Locale } from '@/types';

interface Props {
  locale?: Locale;
}
const { locale = DEFAULT_LOCALE } = Astro.props;
const t = useTranslations(locale);
---

<section id="hero">
  <div class="hero-media">
    <Image
      src={heroImage}
      alt={t('hero.imageAlt')}
      widths={[480, 768, 1100, 1440]}
      sizes="(max-width: 860px) 100vw, 58vw"
      loading="eager"
      fetchpriority="high"
    />
  </div>
  <div class="hero-content">
    <div class="hero-inner">
      <SectionBadge label={t('hero.badge')} />
      <h1 class="hero-title">
        {t('hero.title.lead')}
        <Highlight text={t('hero.title.hl')} />
        {' '}{t('hero.title.tail')}
      </h1>
      <p class="hero-sub">{t('hero.sub')}</p>
      <div class="hero-ctas">
        <Button href="#services" variant="primary">{t('cta.discoverServices')}</Button>
        <Button href={localizePath('contact', locale)} variant="outline">
          {t('cta.contactUs')}
        </Button>
      </div>
    </div>
  </div>
</section>

<style>
  #hero {
    position: relative;
    overflow: hidden;
    padding: calc(var(--nav-height) + 44px) 5% var(--section-pad-y);
    background: var(--color-primary);
    color: var(--color-on-primary);
  }
  /* Image plein cadre sur la moitié droite */
  .hero-media {
    position: absolute;
    inset: 0 0 0 auto;
    width: 58%;
    z-index: 0;
    pointer-events: none;
  }
  .hero-media :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    /* dégradé : le bord gauche fond dans le marine */
    -webkit-mask-image: linear-gradient(
      to right,
      transparent 0%,
      rgba(0, 0, 0, 0.45) 24%,
      #000 52%
    );
    mask-image: linear-gradient(to right, transparent 0%, rgba(0, 0, 0, 0.45) 24%, #000 52%);
  }
  /* Voile marine + flou sur la couture pour « coller » texte et image */
  .hero-media::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to right,
      var(--color-primary) 0%,
      color-mix(in srgb, var(--color-primary) 55%, transparent) 30%,
      transparent 58%
    );
    -webkit-backdrop-filter: blur(4px);
    backdrop-filter: blur(4px);
    -webkit-mask-image: linear-gradient(to right, #000 0%, #000 34%, transparent 62%);
    mask-image: linear-gradient(to right, #000 0%, #000 34%, transparent 62%);
  }
  .hero-content {
    position: relative;
    z-index: 1;
    max-width: var(--content-max);
    margin: 0 auto;
  }
  .hero-inner {
    max-width: 52%;
  }
  #hero :global(.badge) {
    color: var(--color-teal-bright);
    background: rgba(255, 255, 255, 0.08);
  }
  .hero-title {
    font-family: var(--font-display);
    font-size: clamp(2.2rem, 5vw, 3.6rem);
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin: 18px 0;
  }
  .hero-sub {
    color: var(--color-on-primary-variant);
    max-width: 46ch;
  }
  .hero-ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    margin-top: 28px;
  }
  .hero-ctas :global(.btn-outline) {
    color: var(--color-on-primary);
    border-color: rgba(255, 255, 255, 0.4);
  }
  .hero-ctas :global(.btn-outline):hover {
    background: rgba(255, 255, 255, 0.1);
    color: var(--color-on-primary);
  }
  @media (max-width: 860px) {
    #hero {
      min-height: 78vh;
    }
    /* Sur mobile : image plein écran derrière, texte par-dessus */
    .hero-media {
      width: 100%;
    }
    .hero-media :global(img) {
      -webkit-mask-image: linear-gradient(to bottom, rgba(0, 0, 0, 0.55) 0%, transparent 75%);
      mask-image: linear-gradient(to bottom, rgba(0, 0, 0, 0.55) 0%, transparent 75%);
    }
    .hero-media::after {
      background: linear-gradient(to top, var(--color-primary) 18%, transparent 70%);
      -webkit-backdrop-filter: none;
      backdrop-filter: none;
      -webkit-mask-image: none;
      mask-image: none;
    }
    .hero-inner {
      max-width: 100%;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .hero-media::after {
      -webkit-backdrop-filter: none;
      backdrop-filter: none;
    }
  }
</style>
