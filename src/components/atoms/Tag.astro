---
interface Props {
  label: string;
}
const { label } = Astro.props;
---

<span class="tag">{label}</span>

<style>
  .tag {
    display: inline-block;
    padding: 5px 12px;
    border-radius: 8px;
    background: var(--color-overlay-accent-tag);
    border: 1px solid var(--color-border-accent-input);
    color: var(--color-gray);
    font-size: 0.78rem;
    font-weight: 500;
  }
</style>
